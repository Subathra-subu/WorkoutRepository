package jdbc_crud_procedures;

import java.sql.*;

public class EmployeeDAO {
	
	public void insertEmployee(Employee emp) throws SQLException {
		try(Connection con = DBConnection.getConnection();
				CallableStatement cs = con.prepareCall("{call insert_employee(?,?,?,)}")){
			
			cs.setInt(1, emp.getId());
			cs.setString(2, emp.getName());
			cs.setString(3, emp.getDept());
			
			cs.execute();
			System.out.print("Inserted");
		}
		
		catch(Exception e) {
			System.out.print(e);
		}
				
	}
	
	
	public void displayEmployee(Employee emp) throws SQLException {
		try(Connection con = DBConnection.getConnection();
				CallableStatement cs = con.prepareCall("{call get_all_employees}");
				ResultSet rs = cs.executeQuery()){
			
			while(rs.next()) {
				System.out.println(rs.getInt("E_Id")+" | "+rs.getString("E_Name")+" | "+rs.getString("Dept"));
			}
		}
		
		catch(Exception e) {
			e.printStackTrace();
		}
			
		}

}
